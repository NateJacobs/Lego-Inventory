{
    "name": "natejacobs/lego-inventory",
    "type": "project",
    "description": "Your LEGO (R) Set Inventory.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "inspheric/nova-url-field": "^3.0",
        "laravel/framework": "^13.0",
        "laravel/nova": "^5.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "laravel/ui": "^4.6",
        "league/csv": "^9.16",
        "natejacobs/mursten-stock": "dev-master",
        "natejacobs/mursten-track": "dev-master",
        "saumini/count": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.9"
    },
    "repositories": [
        {
            "name": "nova",
            "type": "composer",
            "url": "https://nova.laravel.com"
        },
        {
          "type": "vcs",
          "url": "https://github.com/NateJacobs/mursten-stock"
        },
        {
            "type": "vcs",
            "url": "https://github.com/NateJacobs/Mursten-Track"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
